# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv/

# Lock file
uv.lock

# Logs
*.log

# Model weights and ONNX exports (large binary — run train_f1_yolo.py to regenerate)
models/*.pt
models/*.yaml
yolov8n.pt
yolo26n.pt
*.pt

# Generated XMP sidecars (output artefacts — not committed)
*.xmp
# Note: we do NOT commit XMP files even for tests; the test script uses an internal baseline.

# Training runs (large — regenerate via train_f1_yolo.py)
runs/

# Downloaded datasets (large — regenerate via download script)
datasets/
*.zip

# Scores CSV (regenerate via cull_photos.py --dump-scores)
scores*.csv

# Experimental and temporary files
_*.py
_*.csv
eval_output.txt
fence_eval_output.txt
train_v2.log
nul
temp_*.txt
top_params*.txt
fence_eval_results.json

# Preview tree (hardlinked images, regenerate via make_preview.py)
preview/
scores_preview.csv
test_import/

# Error review analysis (separate from production code)
error_review/

# Training data and labeled images (large, regenerate via extract scripts)
p4_data/
fence_label/
vehicle_orientation_labels/

# Model checkpoints (large binary, regenerate via training scripts)
fence_classifier_checkpoints/*.pth
p4_model_checkpoints/*.pt
p4_model_checkpoints/*.onnx

# macOS
.DS_Store

# Raw image files
*.jpg
!tests/test_img/*.jpg
*.jpeg
*.png
*.bmp
*.gif
*.tiff
*.nef
*.arw
*.hif
*.HIF
*.NEF
*.ARW
*.bin
auto_cull
external/
